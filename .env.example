# Copy to .env and fill in values. Never commit .env to git.
# On VPS: create .env from this file with production values.

# ---------- Database ----------
# Option 1: single URL
# DATABASE_URL=postgresql://user:password@host:5432/BCR_CAR_HIRE

# Option 2: separate vars (defaults: host=localhost, port=5432, name=BCR_CAR_HIRE)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=BCR_CAR_HIRE
DB_USER=postgres
DB_PASSWORD=your_db_password

# ---------- Auth (required for login/session on VPS) ----------
# Use a long random string in production (e.g. openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-change-in-production

# ---------- SMTP (for contact form, dealer contact, booking emails) ----------
SMTP_HOST=bestcarrentaldubai.ae
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@bestcarrentaldubai.ae
SMTP_PASS=your_smtp_password

# Optional: default "to" for main contact form when no vendor (not used by dealer/booking)
# CONTACT_TO_EMAIL=lcruae6@gmail.com
